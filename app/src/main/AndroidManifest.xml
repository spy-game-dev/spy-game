<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".SpyGameApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SpyGame">

        <!--
            MainActivity — единственная Activity.

            android:theme = Theme.SpyGame.Splash:
              Система читает эту тему и показывает Splash Screen ДО
              первого кадра Compose. После installSplashScreen() в коде
              Activity применяется postSplashScreenTheme = Theme.SpyGame.

            android:windowSoftInputMode = adjustResize:
              При появлении клавиатуры (если понадобится) контент сжимается,
              а не уходит за клавиатуру.

            android:exported = true: обязательно для launcher-Activity
              на Android 12+ (API 31+).
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.SpyGame.Splash"
            android:windowSoftInputMode="adjustResize">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

    </application>

</manifest>
